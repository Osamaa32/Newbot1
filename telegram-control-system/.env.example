# ═══════════════════════════════════════════
# Telegram Multi-Account Control System
# ═══════════════════════════════════════════

# ─── Control Bot (from @BotFather) ───
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_PASSWORD=your_secure_admin_password
OWNER_ID=your_telegram_user_id

# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/telegram_bot_db

# ─── Redis (optional - for caching & session) ───
REDIS_URL=redis://localhost:6379/0

# ─── API Server ───
API_PORT=8000
API_HOST=0.0.0.0

# ─── Dashboard ───
DASHBOARD_PORT=3000
SECRET_KEY=your_very_secret_jwt_key_change_this

# ─── Health Check ───
HEALTH_PORT=8080

# ─── Logging ───
LOG_LEVEL=INFO

# ─── Railway Specific ───
RAILWAY_ENVIRONMENT=production
