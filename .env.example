# Railway provides DATABASE_URL automatically when you add PostgreSQL
# For local development:
DATABASE_URL=postgresql://user:password@localhost:5432/telegram_bot

# Admin account (for command interface only — ONLY this goes in env!)
# All other accounts are added dynamically via /addaccount command
ADMIN_API_ID=12345678
ADMIN_API_HASH=abcdef1234567890abcdef1234567890
ADMIN_PHONE=+966500000001

# Optional: pre-authenticated session string (auto-generated after first login)
# ADMIN_SESSION=1BQANOTEuMAA...

# Command group settings
COMMAND_GROUP_ID=-1002311800895
FALLBACK_GROUP_ID=-1002353780992

# Rate limiting
RATE_LIMIT_THRESHOLD=4
RATE_LIMIT_WINDOW_HOURS=24
